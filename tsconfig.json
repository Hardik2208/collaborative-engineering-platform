{
  "compilerOptions": {
    "target": "ES2022",

    "module": "commonjs",

    "moduleResolution": "node",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}
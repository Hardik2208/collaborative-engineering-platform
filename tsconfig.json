{
  "compilerOptions": {
    "target": "ES2022",

    "module": "commonjs",

    "moduleResolution": "node",

    "rootDir": ".",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": [
      "node",
      "jest"
    ],

    "sourceMap": true,

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src",
    "tests"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}